{
  "name": "antigravity-account-switcher",
  "displayName": "Antigravity Profile Switcher",
  "description": "Manage and switch saved local Antigravity profiles",
  "version": "2.4.0",
  "publisher": "sloppyadaptation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eriktechgrounds/antigravity-account-switcher"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-switcher.saveProfile",
        "title": "Antigravity: Save Current Profile"
      },
      {
        "command": "antigravity-switcher.switchProfile",
        "title": "Antigravity: Switch Profile"
      },
      {
        "command": "antigravity-switcher.deleteProfile",
        "title": "Antigravity: Delete Profile"
      },
      {
        "command": "antigravity-switcher.listProfiles",
        "title": "Antigravity: List Profiles"
      },
      {
        "command": "antigravity-switcher.setActiveProfile",
        "title": "Antigravity: Set Active Profile (No Restart)"
      }
    ],
    "configuration": {
      "title": "Antigravity Profile Switcher",
      "properties": {
        "antigravitySwitcher.maxProfiles": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 5,
          "description": "Maximum number of profiles allowed. The current status bar UI supports 5 slots."
        },
        "antigravitySwitcher.profilesDirectory": {
          "type": "string",
          "default": "",
          "description": "Custom directory to store profiles (leave empty for default)."
        },
        "antigravitySwitcher.dataDir": {
          "type": "string",
          "default": "",
          "description": "Override the Antigravity data directory (optional). Useful on Linux/macOS if auto-detection misses your install."
        },
        "antigravitySwitcher.executablePath": {
          "type": "string",
          "default": "",
          "description": "Override the Antigravity executable path (optional)."
        },
        "antigravitySwitcher.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable extra diagnostic logging for path resolution and profile operations."
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}